# ============================================================================
# NextFace — Template de Variáveis de Ambiente
# Copie este arquivo para .env (NUNCA commite o .env) e preencha os valores.
# Ordem dos blocos = ordem recomendada de obtenção.
# ============================================================================

# ----------------------------------------------------------------------------
# 1) INFRAESTRUTURA LOCAL (cria você mesmo)
# ----------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# Postgres (rode 'docker compose up postgres' ou Neon/Supabase/Railway)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/nextface

# Redis (filas BullMQ — pode rodar via docker)
REDIS_URL=redis://localhost:6379

# Segredos internos — gere com: openssl rand -base64 48
JWT_SECRET=
SESSION_SECRET=
ENCRYPTION_KEY=                 # 32 bytes base64, AES-256 p/ tokens de terceiros
WEBHOOK_SIGNING_SECRET=

# Object storage (S3 / R2 / Spaces) — escolha um provedor
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=nextface-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ----------------------------------------------------------------------------
# 2) IA — TEXTO, IMAGEM, VOZ, VÍDEO
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=              # https://console.anthropic.com/settings/keys
OPENAI_API_KEY=                 # https://platform.openai.com/api-keys (fallback / DALL-E / TTS)
ELEVENLABS_API_KEY=             # voice cloning — https://elevenlabs.io/app/settings/api-keys
HEYGEN_API_KEY=                 # AI avatars — https://app.heygen.com/settings/api
SYNTHESIA_API_KEY=              # opcional — https://app.synthesia.io/integrations/api
REPLICATE_API_TOKEN=            # opcional — modelos open-source (Flux, etc.)
RUNWAY_API_KEY=                 # opcional — vídeo

# ----------------------------------------------------------------------------
# 3) META — FACEBOOK + INSTAGRAM + WHATSAPP + ADS + PIXEL CAPI
# Tudo é gerado em UMA App no https://developers.facebook.com
# ----------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v22.0          # versão da Graph API
META_BUSINESS_ID=               # Business Manager ID
META_SYSTEM_USER_ID=
META_SYSTEM_USER_TOKEN=         # token de longa duração (recomendado)
META_AD_ACCOUNT_ID=             # formato: act_XXXXXXXXXXXX
META_PAGE_ID=
META_IG_BUSINESS_ACCOUNT_ID=
META_PIXEL_ID=
META_PIXEL_CAPI_TOKEN=          # token de Conversions API
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback

# WhatsApp Business Platform (Cloud API) — mesma App Meta
WHATSAPP_WABA_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PERMANENT_TOKEN=
WHATSAPP_VERIFY_TOKEN=          # string que você inventa p/ verificar webhook
WHATSAPP_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# 4) TIKTOK FOR BUSINESS — ADS + ORGÂNICO + PIXEL
# Console: https://business-api.tiktok.com/portal
# ----------------------------------------------------------------------------
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_BC_ID=                   # Business Center ID
TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_TOKEN=            # Events API token
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback

# ----------------------------------------------------------------------------
# 5) GOOGLE — YOUTUBE DATA + UPLOAD + ANALYTICS + (OPCIONAL) GOOGLE ADS
# Console: https://console.cloud.google.com
# ----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=           # gerado após primeiro OAuth do usuário
YOUTUBE_API_KEY=                # API key pública (somente leitura/quota)
GOOGLE_ADS_DEVELOPER_TOKEN=     # opcional, p/ YouTube Ads + Search/Display
GOOGLE_ADS_CUSTOMER_ID=         # opcional, formato 123-456-7890

# ----------------------------------------------------------------------------
# 6) TELEGRAM — BOTS + CHANNELS + GROUPS
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=             # gerado pelo @BotFather no Telegram
TELEGRAM_CHANNEL_ID=            # @username ou -100XXXXXXXXXX
TELEGRAM_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# 7) PLATAFORMAS DE INFOPRODUTOS (escolha as que vai usar)
# ----------------------------------------------------------------------------
# Kiwify — https://dashboard.kiwify.com.br → Apps
KIWIFY_CLIENT_ID=
KIWIFY_CLIENT_SECRET=
KIWIFY_ACCOUNT_ID=
KIWIFY_WEBHOOK_SECRET=

# Hotmart — https://developers.hotmart.com
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=
HOTMART_BASIC_TOKEN=
HOTMART_HOTTOK=                 # validação de webhook
HOTMART_ENV=sandbox             # sandbox | production

# Eduzz — https://api.eduzz.com
EDUZZ_PUBLIC_KEY=
EDUZZ_API_KEY=
EDUZZ_EMAIL=

# Monetizze — https://monetizze.com.br → Ferramentas → API
MONETIZZE_API_TOKEN=

# HeroSpark — Painel → Configurações → API
HEROSPARK_API_KEY=

# Ticto — Painel → Integrações
TICTO_API_KEY=

# Braip (opcional)
BRAIP_API_KEY=

# ----------------------------------------------------------------------------
# 8) PIXEL PRÓPRIO + SHORT URL TRACKER (opcional inicialmente)
# ----------------------------------------------------------------------------
NEXTFACE_PIXEL_SECRET=          # assina eventos enviados pelo pixel
SHORT_URL_DOMAIN=nxt.fc         # domínio próprio para encurtador

# ----------------------------------------------------------------------------
# 9) OBSERVABILIDADE & NOTIFICAÇÕES (opcional)
# ----------------------------------------------------------------------------
SENTRY_DSN=
RESEND_API_KEY=                 # e-mail transacional
DISCORD_WEBHOOK_URL=            # alertas internos

# ----------------------------------------------------------------------------
# 10) AGENTE AUTÔNOMO — CONFIG OPERACIONAL
# ----------------------------------------------------------------------------
AUTONOMY_MODE_DEFAULT=copilot    # observer | copilot | autonomous | sovereign
DAILY_BUDGET_HARD_CAP=500        # cap absoluto em R$ por conta no MVP
ENABLE_REAL_PUBLISHING=false     # mantenha false até validar ambiente
