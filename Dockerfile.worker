FROM node:22-alpine

WORKDIR /app

RUN npm install -g pnpm@9

# Copiar manifests do monorepo
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./

# Copiar packages, worker e prisma (web incluso para prisma generate)
COPY packages/ ./packages/
COPY apps/worker/ ./apps/worker/
COPY apps/web/package.json ./apps/web/package.json
COPY apps/web/prisma/ ./apps/web/prisma/

# Instalar dependências (resolve workspace:*)
RUN pnpm install --frozen-lockfile

# Gerar Prisma client com a versão correta instalada pelo pnpm (6.x)
RUN pnpm --filter @nextface/web exec prisma generate

# Instalar claude CLI para subprocess gateway
RUN npm install -g @anthropic-ai/claude-code

# Build worker
RUN pnpm --filter @nextface/worker build

EXPOSE 9000

CMD ["sh", "apps/worker/start.sh"]
