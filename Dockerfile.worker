FROM node:22-alpine

WORKDIR /app

# pnpm
RUN npm install -g pnpm@9

# Copiar manifests do monorepo
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./

# Copiar packages e apps necessários
COPY packages/ ./packages/
COPY apps/worker/ ./apps/worker/
COPY apps/web/prisma/ ./apps/web/prisma/

# Instalar dependências (resolve workspace:*)
RUN pnpm install --frozen-lockfile

# Gerar Prisma client
RUN pnpm --filter @nextface/worker exec prisma generate --schema=../../apps/web/prisma/schema.prisma 2>/dev/null || \
    npx --yes prisma generate --schema=apps/web/prisma/schema.prisma

# Instalar claude CLI para subprocess gateway
RUN npm install -g @anthropic-ai/claude-code

# Build worker
RUN pnpm --filter @nextface/worker build

EXPOSE 9000

CMD ["sh", "apps/worker/start.sh"]
